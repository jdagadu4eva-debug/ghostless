# Copy this file to ".env" and fill in your values.
# Never commit the real .env file — it is git-ignored on purpose.

# Required: your Anthropic API key (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: which Claude model to use. Default is claude-sonnet-4-6.
# Options: claude-sonnet-4-6 | claude-opus-4-7 | claude-opus-4-8 | claude-haiku-4-5-20251001
# Opus models are higher quality but cost more per analysis.
GHOSTLESS_MODEL=claude-sonnet-4-6

# Optional: port to run on locally (most hosts set this automatically).
PORT=3000
